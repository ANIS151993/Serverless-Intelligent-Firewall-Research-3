PYTHONUNBUFFERED=1
PYTHONPATH={{ aslf_install_dir }}/src
{% if aslf_jwt_secrets | length > 0 %}
ASLF_JWT_SECRETS={{ aslf_jwt_secrets | join(',') }}
{% elif aslf_jwt_secret | default('') %}
ASLF_JWT_SECRET={{ aslf_jwt_secret }}
{% endif %}
ASLF_ALLOW_EPHEMERAL_JWT={{ aslf_allow_ephemeral_jwt | ternary('true', 'false') }}
ASLF_ALLOWED_ORIGINS={{ aslf_allowed_origins }}
SIF_DRY_RUN={{ aslf_dry_run | ternary('true', 'false') }}

